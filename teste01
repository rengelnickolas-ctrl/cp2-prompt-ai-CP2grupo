        "    \"\"\"Chatbot com input do usuário em tempo real.\"\"\"\n",
        "    historico = [\n",
        "        {\"role\": \"system\", \"content\": system_prompt}\n",
        "    ]\n",
        "\n",
        "    print(\"=\" * 60)\n",
        "    print(\"💬 CHATBOT iFood — MODO INTERATIVO\")\n",
        "    print(\"   Digite sua mensagem e pressione Enter.\")\n",
        "    print(\"   Para encerrar, digite: sair\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    while True:\n",
